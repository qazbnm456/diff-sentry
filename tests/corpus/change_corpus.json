      "family": "obfuscated-ci-payload",
      "key_rule": "obfuscated-payload",
      "expected_signal": true,
      "expected_rules": ["ci-shell-injection", "command-substitution", "high-entropy-blob", "obfuscated-payload", "workflow-tamper"],
      "event": {
