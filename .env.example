# diff-sentry — model ROLES + runtime knobs (copy to .env; a live run needs these + a Deno sandbox).

# --- Model roles (required for a live `pr`/`issue`/`classify` run) ---
# planner: a cheap, INJECTION-RESISTANT orchestrator that holds the diff in the REPL and triages.
DS_ROOT_LM=your-planner-model
# analyst: an expensive brain reached via llm_query for a subtle source->sink (short questions only).
DS_SUB_LM=your-analyst-model
# One OpenAI-compatible proxy serves all roles. When DS_BASE_URL is set the model names are the plain
# ids your endpoint serves (e.g. qwen/qwen3-next), not litellm-prefixed.
DS_BASE_URL=https://your-openai-compatible-endpoint/v1
DS_API_KEY=sk-...

# --- OR: run planner + analyst on a Claude Pro/Max SUBSCRIPTION (no API key) ---
# Give a role the `claude-agent-sdk/<id>` prefix and it runs on your personal Claude subscription via
# the official Claude Agent SDK (the vendored diff_sentry/claude_agent_lm.py) — each call a pure
# completion (no tools, no filesystem, no settings leakage). Prerequisites: `uv sync --extra
# subscription`; the Claude Code CLI installed and logged in (`claude` → /login, or `claude
# setup-token` → export CLAUDE_CODE_OAUTH_TOKEN); and you MUST `unset ANTHROPIC_API_KEY` — the CLI
# silently prefers it and would bill API credit (the adapter refuses to start while it is set). Prefer
# full model ids over aliases (which drift over time).
#   DS_ROOT_LM=claude-agent-sdk/claude-sonnet-5     # planner on Sonnet 5
#   DS_SUB_LM=claude-agent-sdk/claude-fable-5       # analyst on Fable 5
# DS_BASE_URL/DS_API_KEY are then unused BY THESE TWO ROLES, but the CLASSIFIER still needs its own
# OpenAI-compatible endpoint — a subscription-only end-to-end run is NOT supported. You MUST set
# DS_CLASSIFIER_LM to a real model id (and DS_CLASSIFIER_BASE_URL/DS_CLASSIFIER_API_KEY if it's a
# separate box); leaving it UNSET makes the classifier inherit the `claude-agent-sdk/…` DS_SUB_LM and
# from_env fails LOUD (the classifier uses an OpenAI client, not the Agent SDK). Budgets use the SAME
# env vars as proxy mode. Expect ~2-5s CLI-spawn overhead per call, so keep runs interactive (not batch).
# DS_PLANNER_MAX_TOKENS is inert on this path — the Agent SDK exposes no token/sampling controls.

# --- Second-stage classifier (the swappable seam; defaults to the analyst model on the same proxy —
#     unless the analyst rides the subscription, in which case DS_CLASSIFIER_LM is REQUIRED, see above) ---
# DS_CLASSIFIER_LM=your-strong-classifier
# DS_CLASSIFIER_CIRCUIT_BREAK=4

# --- RLM runtime ---
# DS_INTERPRETER=pyodide       # read-not-execute: the classifier NEVER runs the change. `deno` is an alias.
# DS_MAX_ITERATIONS=25
# DS_MAX_LLM_CALLS=8           # caps ONLY analyst (llm_query) escalations
# DS_ADAPTER=json              # portable structured output (OpenAI + vLLM/NIM)
# DS_PLANNER_MAX_TOKENS=16384  # generous, so a reasoning planner isn't truncated to empty content

# --- Enrichment fetch (OFF by default — an exfil surface on attacker-authored input; GitHub-allowlisted) ---
# DS_ENABLE_FETCH=false
# DS_FETCH_ALLOW_CIDRS=198.18.0.0/16   # only if behind a fake-IP proxy / split-DNS VPN

# --- Host-side SIEM emitter (opt-in; deterministic POST after the run) ---
# DS_SIEM_WEBHOOK_URL=https://your-siem/intake
# DS_SIEM_TOKEN=...
# DS_EMIT_ON=suspicious,malicious
